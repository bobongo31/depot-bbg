RewriteEngine On

# Rediriger tout le trafic de l'ancien domaine nip.io vers keynsoft.online
RewriteCond %{HTTP_HOST} ^(172\.233\.244\.133\.nip\.io|gic\.172\.233\.244\.133\.nip\.io)$ [NC]
RewriteRule ^(.*)$ https://keynsoft.online/$1 [R=301,L]

# Forcer HTTPS si ce n'est pas déjà le cas (sur keynsoft.online ou autre)
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Paramètres PHP
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value memory_limit 256M
php_value max_execution_time 300
php_value max_input_time 300


# ----------------------------
# Mise en cache (cache navigateur)
# ----------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # Images : cache 3 mois
    ExpiresByType image/jpg "access plus 3 months"
    ExpiresByType image/jpeg "access plus 3 months"
    ExpiresByType image/gif "access plus 3 months"
    ExpiresByType image/png "access plus 3 months"
    ExpiresByType image/webp "access plus 3 months"
    ExpiresByType image/svg+xml "access plus 3 months"
    ExpiresByType image/x-icon "access plus 3 months"

    # JavaScript : cache 2 semaines
    ExpiresByType application/javascript "access plus 2 weeks"
    ExpiresByType text/javascript "access plus 2 weeks"

    # CSS : cache 2 semaines
    ExpiresByType text/css "access plus 2 weeks"

    # HTML et autres : cache court
    ExpiresByType text/html "access plus 1 hour"
    ExpiresDefault "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    # Cache-Control pour les fichiers statiques
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=7776000, public"
    </FilesMatch>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "max-age=1209600, public"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "max-age=3600, public"
    </FilesMatch>
</IfModule>

# Activer GZIP pour les fichiers HTML, CSS, JS, JSON, XML, etc.
AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json application/xml text/xml application/x-javascript

# Désactiver la compression pour certains types de fichiers (par exemple, SVG, PDF, ZIP)
SetEnvIf Request_URI \.svg$ no-gzip
SetEnvIf Request_URI \.pdf$ no-gzip
SetEnvIf Request_URI \.zip$ no-gzip

# Optimiser pour les navigateurs plus anciens
BrowserMatch ^Mozilla/4 gzip-only-text/html
BrowserMatch ^Mozilla/4\.0[678] no-gzip
BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
